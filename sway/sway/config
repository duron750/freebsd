#
# Complete and Consolidated Sway Configuration for Dan
#
# This file includes all your original settings, the cheat sheet configuration,
# and the robust fix to ensure the window stays in the background.
#

### Variables
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left g
set $down h
set $up j
set $right k
# Your preferred terminal emulator
set $term foot
# Your preferred application launcher
set $menu wofi --show drun
set $bg_path /usr/local/share/backgrounds/mate/abstract/Silk.png
#set $lock_cmd /usr/bin/local/swaylock -i $bg_path -s fill -f
set $lock_cmd /home/dan/.config/sway/lock.sh

### Output configuration
output * bg $bg_path fill

# ... (Standard Sway Config Sections Below) ...

### Input configuration
    input type:touchpad {
        dwt enabled
        tap enabled
        middle_emulation enabled
        drag_lock disabled
	drag disabled
    }

### Key bindings
# Basics:
     bindsym $mod+Return exec $term
     bindsym $mod+Shift+q kill
     bindsym $mod+d exec $menu
#     bindsym $mod+Shift+f exec flatpak run com.brave.Browser
     bindsym $mod+Shift+f exec librewolf
     bindsym Print exec grim -g "$(slurp)" $HOME/Pictures/screenshot-$(date +%Y%m%d%H%M%S).png && notify-send "Screenshot Area Captured" -t 1500
     bindsym $mod+Print exec grim $HOME/Pictures/screenshot-$(date +%Y%m%d%H%M%S).png && notify-send "Screenshot Screen Captured" -t 1500
     floating_modifier $mod normal
     bindsym $mod+Shift+c reload
     bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
# Moving around:
     bindsym $mod+$left focus left
     bindsym $mod+$down focus down
     bindsym $mod+$up focus up
     bindsym $mod+$right focus right
     bindsym $mod+Left focus left
     bindsym $mod+Down focus down
     bindsym $mod+Up focus up
     bindsym $mod+Right focus right
     bindsym $mod+Shift+$left move left
     bindsym $mod+Shift+$down move down
     bindsym $mod+Shift+$up move up
     bindsym $mod+Shift+$right move right
     bindsym $mod+Shift+Left move left
     bindsym $mod+Shift+Down move down
     bindsym $mod+Shift+Up move up
     bindsym $mod+Shift+Right move right
# Workspaces:
     bindsym $mod+1 workspace number 1
     bindsym $mod+2 workspace number 2
     bindsym $mod+3 workspace number 3
     bindsym $mod+4 workspace number 4
     bindsym $mod+5 workspace number 5
     bindsym $mod+6 workspace number 6
     bindsym $mod+7 workspace number 7
     bindsym $mod+8 workspace number 8
     bindsym $mod+9 workspace number 9
     bindsym $mod+0 workspace number 10
     bindsym $mod+Shift+1 move container to workspace number 1
     bindsym $mod+Shift+2 move container to workspace number 2
     bindsym $mod+Shift+3 move container to workspace number 3
     bindsym $mod+Shift+4 move container to workspace number 4
     bindsym $mod+Shift+5 move container to workspace number 5
     bindsym $mod+Shift+6 move container to workspace number 6
     bindsym $mod+Shift+7 move container to workspace number 7
     bindsym $mod+Shift+8 move container to workspace number 8
     bindsym $mod+Shift+9 move container to workspace number 9
     bindsym $mod+Shift+0 move container to workspace number 10
# Layout stuff:
     bindsym $mod+b splith
     bindsym $mod+v splitv
     bindsym $mod+s layout stacking
     bindsym $mod+w layout tabbed
     bindsym $mod+e layout toggle split
     bindsym $mod+f fullscreen
     bindsym $mod+Shift+space floating toggle
     bindsym $mod+space focus mode_toggle
     bindsym $mod+a focus parent
# Scratchpad:
     bindsym $mod+Shift+minus move scratchpad
     bindsym $mod+minus scratchpad show
# Manual screen lock
     bindsym $mod+l exec $lock_cmd
#automatic screen lock
#     bindswitch lid:on exec loginctl suspend

# Resizing containers:
mode "resize" {
     bindsym $left resize shrink width 10px
     bindsym $down resize grow height 10px
     bindsym $up resize shrink height 10px
     bindsym $right resize grow width 10px
     bindsym Left resize shrink width 10px
     bindsym Down resize grow height 10px
     bindsym Up resize shrink height 10px
     bindsym Right resize grow width 10px
     bindsym Return mode "default"
     bindsym Escape mode "default"
}
     bindsym $mod+r mode "resize"

     # Utilities (need pamixer, brightnessctl, mako):
     set $volume_control pamixer
     # Custom variable to hold the command for getting the current percentage (0-100)
     set $brightness_get_pct backlight -q

     bindsym --locked XF86AudioMute exec $volume_control -t  && sh -c 'if $($volume_control --get-mute); then notify-send "Volume" "Muted" -t 1500; else notify-send "Volume" "Unmuted" -t 1500; fi'
     bindsym --locked XF86AudioLowerVolume exec $volume_control -d 2 && notify-send -h string:x-canonical-private-synchronous:volume_notif -h int:value:"$($volume_control --get-volume)" "Volume" -t 1500
     bindsym --locked XF86AudioRaiseVolume exec $volume_control -i 2 && notify-send -h string:x-canonical-private-synchronous:volume_notif -h int:value:"$($volume_control --get-volume)" "Volume" -t 1500
     bindsym --locked XF86AudioMicMute exec $volume_control --default-source -t && 'if $($volume_control --default-source --get-mute); then notify-send "Microphone" "Muted" -t 1500; else notify-send "Microphone" "Unmuted" -t 1500; fi'
     bindsym --locked XF86MonBrightnessDown exec backlight decr 5% && notify-send -h string:x-canonical-private-synchronous:brightness_notif -h int:value:"$($brightness_get_pct)" "Brightness" -t 1500
     bindsym --locked XF86MonBrightnessUp exec backlight incr 5% && notify-send -h string:x-canonical-private-synchronous:brightness_notif -h int:value:"$($brightness_get_pct)" "Brightness" -t 1500

# --- Screen Locking / Idle Management ---
bindswitch --locked lid:on exec $lock_cmd
# Lock the screen after 300 seconds (5 minutes) of inactivity
#exec swayidle -w timeout 900 "$lock_cmd" before-sleep "$lock_cmd"
exec swayidle -w timeout 900 '/home/dan/.config/sway/lock.sh' before-sleep '/home/dan/.config/sway/lock.sh'
   
# You can optionally set a command to turn off your displays after a longer period, 
# for example, after 10 minutes (600 seconds)
# timeout 600 'swaymsg "output * dpms off"' \
# resume 'swaymsg "output * dpms on"'

# Forțează toate ferestrele aplicației linhpsdr să fie floating
for_window [app_id="linhpsdr"] floating enable
for_window [class="linhpsdr"] floating enable
# Forțează Cosmic Files să fie mereu floating
for_window [app_id="thunar"] floating enable, move position center, resize set 1100 700
for_window [app_id="foot"] layout tabbed
# Forțează toate ferestrele aplicației cqrlog să fie floating
#for_window [app_id="Cqrlog"] floating enable
#for_window [class="Cqrlog"] floating enable
#make sure if there are authentication windows, they pop on same desktop
for_window [window_role="polkit-gnome-authentication-agent-1"] floating enable, move position center

### AUTOSTART COMMANDS
# CRITICAL: These run once when Sway starts.
exec dbus-update-activation-environment --all
# waybar, nm-applet are for top bar, mako is the notification daemon
exec waybar &  mako &
# open the botton waybar
exec waybar -c ~/.config/waybar/config-dock.jsonc -s ~/.config/waybar/style-dock.css &
# necesary for saving/restoring passwords for VPN
exec /usr/bin/local/gnome-keyring-daemon --start --components=secrets,ssh,pkcs11
# necesary to run applications as sudo, for example libvirtd daemon
exec /usr/libexec/polkit-gnome-authentication-agent-1 &
exec /home/dan/bin/googledrive.sh &
exec nextcloud --background &
# those are all necesary for transferring files between apps, for example open/save from app to disk, copy-paste etc. Without them, the modal window to save file will not appear
exec --no-startup-id /usr/libexec/xdg-desktop-portal &
exec --no-startup-id /usr/libexec/xdg-desktop-portal-gtk &
exec --no-startup-id /usr/libexec/xdg-desktop-portal-wlr &
# needed for sound configuration
#exec pipewire & sleep 1 && wireplumber
# Optional, but recommended for compatibility
#exec --no-startup-id /usr/bin/local/pipewire-pulse
# Autotiling
exec_always autotiling &
